# Groq — free Whisper transcription
# Get key: console.groq.com (free, no credit card)
GROQ_API_KEY=gsk_...

# NVIDIA NIM — free LLM (Llama + Mistral)
# Get key: build.nvidia.com → get API key (free tier)
NVIDIA_API_KEY=nvapi-...

# Deepgram — transcription fallback (free 45min/month)
# Get key: console.deepgram.com
DEEPGRAM_API_KEY=...

# Redis
REDIS_URL=redis://localhost:6379

# Workers
WORKER_COUNT=4
GROQ_TIMEOUT_SECONDS=8.0
NVIDIA_TIMEOUT_SECONDS=30.0
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_RESET_SECONDS=300
LOG_LEVEL=INFO
PORT=8000

# Supabase Storage & Documents Webhook
WEBHOOK_SECRET=change-me-to-random-string
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Environment
ENVIRONMENT=production
SENTRY_DSN=
